# Circle API Credentials
# Get these from https://console.circle.com
CIRCLE_API_KEY=your_circle_api_key
ENTITY_SECRET=your_entity_secret

# Merchant Wallet (Your Circle Developer Controlled Wallet address or MetaMask EOA)
CIRCLE_WALLET_ADDRESS=0x...
# Private Key for withdrawals (Mandatory for automated withdrawals from Dashboard)
SELLER_PRIVATE_KEY=your_private_key_here

# Wallet Set ID (optional - will auto-create if not provided)
WALLET_SET_ID=

# Network Configuration
GATEWAY_CONTRACT=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
USDC_ARC=0x3600000000000000000000000000000000000000
ARC_RPC=https://rpc.testnet.arc.network

# Pricing Configuration
PRICE_PER_MB=0.0015
MB_PER_PAYMENT=1
AUTO_RENEW_THRESHOLD=0.8

# Server
PORT=3000
